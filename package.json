{
  "name": "qa-platform",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "pnpm --filter './packages/**' build && pnpm --filter @qa/api --filter @qa/web build",
    "dev": "pnpm --parallel --filter @qa/api --filter @qa/web dev",
    "lint": "pnpm --recursive lint",
    "type-check": "pnpm --recursive type-check",
    "test": "pnpm --recursive test",
    "test:e2e": "pnpm --filter api test:e2e",
    "dev:provision": "node scripts/dev-provision.cjs",
    "dev:provision:all": "node scripts/dev-provision.cjs",
    "db:migrate:deploy": "pnpm --filter @qa/prisma-master migrate:deploy",
    "db:migrate:deploy:all": "pnpm --filter @qa/prisma-master migrate:deploy ; pnpm --filter @qa/prisma-tenant migrate:deploy",
    "db:generate": "pnpm --recursive db:generate",
    "db:seed": "node scripts/seed-runner.cjs",
    "smoke:auth": "node scripts/smoke-auth.cjs",
    "smoke:auth:queues": "node scripts/smoke-auth.cjs --check-eval-queue --check-eval-verifier-queue"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "prettier": "^3.2.5",
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.12.0"
}
