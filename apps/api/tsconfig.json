{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "commonjs",
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "ES2021",
    "sourceMap": true,
    "outDir": "dist",
    "rootDir": "src",
    "incremental": false,
    "composite": false,
    "paths": {
      "@qa/shared": ["../../packages/shared/dist"],
      "@qa/shared/*": ["../../packages/shared/dist/*"],
      "@qa/config": ["../../packages/config/dist"],
      "@qa/config/*": ["../../packages/config/dist/*"],
      "@qa/prisma-master": ["../../packages/prisma-master/dist"],
      "@qa/prisma-master/*": ["../../packages/prisma-master/dist/*"],
      "@qa/prisma-tenant": ["../../packages/prisma-tenant/dist"],
      "@qa/prisma-tenant/*": ["../../packages/prisma-tenant/dist/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "test"]
}
