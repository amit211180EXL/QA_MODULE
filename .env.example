# ─── App ────────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
API_URL=http://localhost:3000

# ─── Master DB ──────────────────────────────────────────────────────────────────
MASTER_DATABASE_URL=postgresql://qa_master:masterpass@localhost:5432/qa_master

# ─── Redis ──────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_PASSWORD=

# ─── JWT (min 32 chars each) ─────────────────────────────────────────────────────
JWT_SECRET=CHANGE_ME_jwt_secret_minimum_32_characters_here
JWT_EXPIRES_IN=15m
REFRESH_SECRET=CHANGE_ME_refresh_secret_minimum_32_characters
REFRESH_EXPIRES_IN=30d

# ─── Encryption key — 64 hex chars = 32 bytes ─────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
MASTER_ENCRYPTION_KEY=CHANGE_ME_64_hex_characters_here_00000000000000000000000000000000

# ─── Tenant DB provisioning ──────────────────────────────────────────────────────
TENANT_DB_HOST=localhost
TENANT_DB_PORT=5432
TENANT_DB_SUPERUSER=qa_superuser
TENANT_DB_SUPERUSER_PASSWORD=superpass

# ─── Email ───────────────────────────────────────────────────────────────────────
EMAIL_FROM=noreply@qa-platform.local
SMTP_HOST=localhost
SMTP_PORT=1025
# SMTP_USER=
# SMTP_PASS=

# ─── Stripe (optional in dev) ────────────────────────────────────────────────────
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# ─── Platform admin (optional) ───────────────────────────────────────────────────
# PLATFORM_ADMIN_TOKEN=CHANGE_ME_min_32_chars
